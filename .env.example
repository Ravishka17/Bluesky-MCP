# Bluesky MCP Server - Environment Variables Template
# ===================================================
# SECURITY WARNING: Never commit actual credentials to version control!
# These are template variables - actual values should be provided externally

# Bluesky Service URL (default: https://bsky.social)
BLUESKY_SERVICE_URL=https://bsky.social

# Optional: Public API URL for unauthenticated requests
BLUESKY_PUBLIC_API_URL=https://public.api.bsky.app

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Cache Configuration (optional)
ENABLE_CACHE=false
CACHE_TTL_SECONDS=300

# Server Configuration
PORT=8000
NODE_ENV=production

# ============================================
# CREDENTIAL MANAGEMENT
# ============================================
# IMPORTANT: Credentials should NEVER be stored in Vercel Environment Variables
# or committed to version control.
#
# The Bluesky app password is provided externally via request headers:
# - X-BLUESKY-IDENTIFIER: Your Bluesky handle/email
# - X-BLUESKY-PASSWORD: Your app-specific password
#
# For local development, you can use a .env.local file (not committed to git)
# or export them as environment variables before running.
#
# Example for local development:
#   export BLUESKY_IDENTIFIER="your-handle.bsky.social"
#   export BLUESKY_APP_PASSWORD="your-app-password"
# ============================================